# PerfectPixel — API 키 환경변수 예시
# 이 파일을 .env 또는 .env.local로 복사한 뒤 사용할 프로바이더의 키만 채우세요.
# (앱 내 설정 화면에서 직접 입력해도 됩니다. 설정 파일이 환경변수보다 우선합니다.)
#
# .env / .env.local 은 .gitignore 에 의해 커밋되지 않습니다.

# Gemini (Google AI Studio) — 기본 프로바이더
GEMINI_API_KEY=
# GOOGLE_API_KEY 도 폴백으로 인식됩니다.

# OpenRouter
OPENROUTER_API_KEY=

# fal.ai
FAL_KEY=
# FAL_API_KEY 도 폴백으로 인식됩니다.

# BytePlus (ARK)
BYTEPLUS_API_KEY=
# ARK_API_KEY 도 폴백으로 인식됩니다.
